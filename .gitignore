# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# PyInstaller
*.manifest
*.spec

# Unit test / coverage reports
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# Virtual environments
venv/
ENV/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Jupyter Notebook
.ipynb_checkpoints

# Environment variables
.env
.env.local

# Temporary files
*.tmp
*.log
# Committed run logs under tests/data/summary (e.g. rpa_oep/Ne.log)
!tests/data/summary/**/*.log


# Jupyter Book build outputs
_build/              # Ignore _build in project root (shouldn't be created, but just in case)
docs/_build/         # Build output in docs/

# LaTeX build artifacts (tests/paper/): track .tex and .pdf only
tests/paper/**/*.aux
tests/paper/**/*.bbl
tests/paper/**/*.blg
tests/paper/**/*.bcf
tests/paper/**/*.fdb_latexmk
tests/paper/**/*.fls
tests/paper/**/*.log
tests/paper/**/*.out
tests/paper/**/*.run.xml
tests/paper/**/*.synctex.gz
tests/paper/**/*.toc
tests/paper/**/*.nav
tests/paper/**/*.snm
tests/paper/**/*.vrb
tests/paper/**/*.xdv
tests/paper/**/*.lof
tests/paper/**/*.lot
tests/paper/**/*.ilg
tests/paper/**/*.idx
tests/paper/**/*.ind
